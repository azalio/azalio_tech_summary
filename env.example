# Telegram bot configuration
# Create a bot via @BotFather, copy the token here.
TELEGRAM_BOT_TOKEN=

# Default chat where errors / non-routed messages go.
# For a personal user ID — find via @userinfobot.
TELEGRAM_DEFAULT_CHAT_ID=

# Channel/chat for the hourly digest. Public channels: "@channel_name".
TELEGRAM_DIGEST_CHAT=@azalio_tech_summary

# Channel/chat for the standalone Reddit digest (images/videos from MEDIA_SUBS).
TELEGRAM_REDDIT_CHAT_ID=

# Comma-separated subreddits for media reposts (images/videos). Empty = disabled.
# Example: REDDIT_MEDIA_SUBS=AIRetrofuturism,coolguides,dataisbeautiful
REDDIT_MEDIA_SUBS=

# Reddit API credentials JSON path (used by standalone_reddit_digest.py).
# REDDIT_CREDENTIALS=~/.config/reddit/credentials.json

# Telegram channel collector (MTProto user account — separate from the bot token
# above; used to pull posts from public channels you specify, not to post).
# Get api_id/api_hash from https://my.telegram.org/apps. Empty TELEGRAM_CHANNELS
# disables the collector silently.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# TELEGRAM_PHONE is only needed for the one-off `auth-start` step; after that
# the session file is sufficient and TELEGRAM_PHONE can be unset/removed.
TELEGRAM_PHONE=
# Comma-separated channels to track. Accepts "@name", "name", or "https://t.me/name".
# Example: TELEGRAM_CHANNELS=@durov,seriouscoder,https://t.me/python_weekly
TELEGRAM_CHANNELS=
# Optional overrides for the Telegram collector.
# TELEGRAM_DIGEST_SCRIPT=/path/to/standalone_telegram_digest.py
# TELEGRAM_SESSION_PATH=/path/to/telegram.session

# Workspace directory — where SQLite DBs and last_summary.txt live.
# Default: ./workspace (relative to repo root).
VIBE_WORKSPACE=./workspace

# Optional: paths to LLM CLIs (gemini / codex). If unset, $PATH is searched.
# GEMINI_BIN=
# CODEX_BIN=

# Optional: yt-dlp binary for Reddit video fallback. Default: yt-dlp from $PATH.
# YT_DLP_PATH=yt-dlp

# Optional API keys (collectors silently skip if empty).
FINNHUB_API_KEY=
NEWSAPI_KEY=
# NVD collector works without a key (5 req/30s); a key raises it to 50 req/30s.
# Request one at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Optional sub-scripts called via subprocess. Leave empty to disable.
# REDDIT_SCRIPT defaults to ./standalone_reddit_digest.py next to main.py.
# REDDIT_SCRIPT=/path/to/standalone_reddit_digest.py
# RU_NEWS_SCRIPT=/path/to/get_ru_news.py
# MARKET_NEWS_SCRIPT=/path/to/market_news_fetcher.py
# PYTHON_BIN / VENV_PYTHON default to the interpreter running main.py (sys.executable).
# Only set these if you need to point sub-scripts at a different Python.
# PYTHON_BIN=/path/to/python
# VENV_PYTHON=/path/to/python
