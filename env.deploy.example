# Copy this to .env.deploy and fill in. Makefile picks it up automatically.
# This file is gitignored — never commit your production target into the repo.

# Leave SSH_JUMP empty for direct SSH; set it to a bastion host if you need to
# tunnel through one (e.g. SSH_JUMP=root@bastion.example.com).
SSH_JUMP   =
SSH_TARGET = azalio@your-vm-ip-or-hostname
REMOTE_DIR = /home/azalio/azalio_tech_summary
