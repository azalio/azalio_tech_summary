# Copy this to .env.deploy and fill in.
# Both `make` (via -include) and a shell `source .env.deploy` read this file, so
# keep the `export KEY=value` form: no spaces around `=`, values unquoted.
# This file is gitignored — never commit your production target into the repo.

# Leave SSH_JUMP empty for direct SSH; set it to a bastion host if you need to
# tunnel through one (e.g. export SSH_JUMP=root@bastion.example.com).
export SSH_JUMP=
export SSH_TARGET=azalio@your-vm-ip-or-hostname
export REMOTE_DIR=/home/azalio/azalio_tech_summary
